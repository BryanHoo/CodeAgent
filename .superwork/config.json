{
  "schemaVersion": 2,
  "packageManager": "pnpm",
  "packages": [
    {
      "name": "root",
      "layers": ["distribution", "cli"]
    },
    {
      "name": "@code-agent/web",
      "layers": ["frontend"]
    },
    {
      "name": "@code-agent/protocol",
      "layers": ["shared", "protocol"]
    },
    {
      "name": "@code-agent/core",
      "layers": ["shared", "domain"]
    },
    {
      "name": "@code-agent/provider-codex",
      "layers": ["backend", "provider"]
    },
    {
      "name": "@code-agent/server",
      "layers": ["backend", "delivery", "persistence"]
    },
    {
      "name": "@code-agent/client",
      "layers": ["frontend", "transport"]
    }
  ],
  "artifactPaths": {
    "designs": ".superwork/prd",
    "plans": ".superwork/plans",
    "specs": ".superwork/spec"
  },
  "verification": ["pnpm check", "pnpm test:e2e"]
}
